{
  "name": "easy-calendar-bot",
  "version": "0.1.0",
  "private": true,
  "description": "ズボラカレンダーの自然文予定パーサと Discord Bot 土台",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
